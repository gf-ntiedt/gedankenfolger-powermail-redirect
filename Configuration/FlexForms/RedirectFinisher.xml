                <type>array</type>
                <el>

                    <redirectTarget>
                        <label>LLL:EXT:gedankenfolger_powermail_redirect/Resources/Private/Language/locallang.xlf:flexform.redirectTarget</label>
                        <config>
                            <type>link</type>
                            <allowedTypes>
                                <numIndex index="0">page</numIndex>
                            </allowedTypes>
                        </config>
                    </redirectTarget>

                    <transferFields>
                        <label>LLL:EXT:gedankenfolger_powermail_redirect/Resources/Private/Language/locallang.xlf:flexform.transferFields</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <itemsProcFunc>Gedankenfolger\GedankenfolgerPowermailRedirect\Form\TransferFieldsItemsProcFunc->getItems</itemsProcFunc>
                            <size>8</size>
                            <maxitems>20</maxitems>
                        </config>
