<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<T3DataStructure>
    <sheets>
        <sRedirect>
            <ROOT>
                <sheetTitle>LLL:EXT:gedankenfolger_powermail_redirect/Resources/Private/Language/locallang.xlf:flexform.sheet.sRedirect</sheetTitle>
                <type>array</type>
                <el>

                    <redirectPageUid>
                        <label>LLL:EXT:gedankenfolger_powermail_redirect/Resources/Private/Language/locallang.xlf:flexform.redirectPageUid</label>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>1</size>
                            <maxitems>1</maxitems>
                            <minitems>0</minitems>
                        </config>
                    </redirectPageUid>

                    <transferFields>
                        <label>LLL:EXT:gedankenfolger_powermail_redirect/Resources/Private/Language/locallang.xlf:flexform.transferFields</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <foreign_table>tx_powermail_domain_model_field</foreign_table>
                            <foreign_table_where>
                                AND {#tx_powermail_domain_model_field}.deleted = 0
                                AND {#tx_powermail_domain_model_field}.hidden = 0
                                AND {#tx_powermail_domain_model_field}.type != 'submit'
                            </foreign_table_where>
                            <fieldWizard>
                                <recordsOverview>
                                    <disabled>1</disabled>
                                </recordsOverview>
                            </fieldWizard>
                            <size>8</size>
                            <maxitems>20</maxitems>
                        </config>
                    </transferFields>

                </el>
            </ROOT>
        </sRedirect>
    </sheets>
</T3DataStructure>
